+    let Some(current_interpreter) = read_elf_interpreter(patchelf_bin, path)? else {
+      return Ok(false);
+    };
+
+    if current_interpreter == target_interpreter {
+      return Ok(false);
+    }
+
+    let output = Command::new(patchelf_bin)
+      .arg("--set-interpreter")
+      .arg(target_interpreter)
+      .arg(path)
+      .output()?;
