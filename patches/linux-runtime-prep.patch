+  fn resolve_patchelf_bin() -> Option<PathBuf> {
+    if let Ok(path) = std::env::var("DONUT_PATCHELF_BIN") {
+      let path = PathBuf::from(path);
+      if path.exists() {
+        return Some(path);
+      }
+    }
+
+    let Ok(path_var) = std::env::var("PATH") else {
+      return None;
+    };
+
+    std::env::split_paths(&path_var)
+      .map(|dir| dir.join("patchelf"))
+      .find(|path| path.exists())
+  }
+
+  fn read_elf_interpreter(
+    patchelf_bin: &Path,
+    path: &Path,
+  ) -> Result<Option<String>, Box<dyn std::error::Error + Send + Sync>> {
+    let output = Command::new(patchelf_bin)
+      .arg("--print-interpreter")
+      .arg(path)
+      .output()?;
+
+    if !output.status.success() {
+      return Ok(None);
+    }
+
+    let interpreter = String::from_utf8_lossy(&output.stdout).trim().to_string();
+    if interpreter.is_empty() {
+      Ok(None)
+    } else {
+      Ok(Some(interpreter))
+    }
+  }
